# Copy this file to .env and fill in values before running the server
# Database connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=duelcode_capstone_project

# JWT secret used to sign authentication tokens
JWT_SECRET=replace_with_a_strong_random_secret

# Server port (optional, defaults to 3000)
PORT=3000

# Optional: enable verbose SQL logging (true/false)
SQL_DEBUG=false

# NOTE: Do NOT commit a real .env file with credentials to version control.
