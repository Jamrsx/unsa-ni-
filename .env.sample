# Copy this file to `.env` and fill in values before running the server
# Example: cp .env.sample .env  (or copy manually on Windows)

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=<your_db_password_here>
DB_NAME=duelcode_capstone_project

# App secrets
JWT_SECRET=supersecretkey
PORT=3000
VITE_API_URL=http://localhost:3000
DEBUG_READ_ONLY=false

# Quick instructions
# 1) Copy to .env and edit values:
#    - On Linux/macOS: `cp .env.sample .env && edit .env`
#    - On Windows (PowerShell): `copy .env.sample .env` then edit `.env` in your editor

# 2) Start server (from project root):
#    node server.js

# 3) (Optional) Start frontend dev server:
#    npm run dev

# 4) Seed a faculty test user and print a FACULTY_TOKEN (useful for QA):
#    node scripts/seed_faculty_token.js

# 5) Run socket QA script (replace token in file or set env variable):
#    - Linux/macOS (inline):
#        FACULTY_TOKEN="<TOKEN>" node for_context/qa_topic_test.js
#    - Windows PowerShell:
#        $env:FACULTY_TOKEN = "<TOKEN>"; node for_context/qa_topic_test.js

# 6) DB helper scripts (for debugging):
#    node for_context/db_recent_problems.js
#    node for_context/db_check_problems.js

# Note: If your MySQL root user has no password (not recommended), set DB_PASS= (empty).
